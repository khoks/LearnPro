# LearnPro environment variables
#
# Copy this file to .env (which is gitignored) and fill in real values.
# This file is the source of truth for which env vars the app reads —
# add new variables here (with placeholder values) before referencing them in code.

# --- LLM provider (Anthropic primary) ---
# ANTHROPIC_API_KEY=
# Optional JSON config for the LLM gateway (provider + role->model overrides).
# Defaults to {"provider":"anthropic"} with the canonical Opus/Haiku role map.
# LEARNPRO_LLM_CONFIG={"provider":"anthropic","models":{"tutor":"claude-opus-4-7"}}

# --- Database ---
# DATABASE_URL=postgresql://learnpro:learnpro@localhost:5432/learnpro
# REDIS_URL=redis://localhost:6379

# --- Auth ---
# AUTH_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Email magic link — when EMAIL_SERVER is unset (self-hosted dev default), Auth.js falls back to
# logging the magic link to stdout so you can click it without configuring SMTP. Set EMAIL_SERVER
# and EMAIL_FROM in production.
# EMAIL_SERVER=smtps://user:pass@smtp.example.com:465
# EMAIL_FROM=LearnPro <noreply@learnpro.local>

# --- Daily LLM token budget (per-user) ---
# 0 = unlimited (self-hosted default). Above 0 enables BudgetGatedLLMProvider on apps/api.
# LEARNPRO_DAILY_TOKEN_LIMIT=0

# --- Sandbox (Piston self-hosted) ---
# PISTON_URL=http://localhost:2000

# --- App ---
# NODE_ENV=development
# APP_URL=http://localhost:3000
# Web → API base URL used by Next.js Route Handlers when proxying to Fastify.
# Defaults to http://localhost:4000 when unset.
# LEARNPRO_API_URL=http://localhost:4000
